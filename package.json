{
  "name": "testify",
  "version": "1.7.0",
  "description": "Open Source Discord Bot",
  "main": "src/index.js",
  "scripts": {
    "prod": "node src/index.js",
    "dev": "cross-env NODE_ENV=development node src/index.js",
    "prod:nodemon": "nodemon src/index.js",
    "dev:nodemon": "cross-env NODE_ENV=development nodemon src/index.js",
    "setup": "npm i && npm run postinstall",
    "postinstall": "node src/scripts/postInstallation.js",
    "update-packages": "npx npm-check-updates -u && npm install",
    "update-ytdl-core": "node src/scripts/ytdlUpdater.js",
    "setup-env:prod": "node src/scripts/setupEnvFile.js",
    "setup-env:dev": "node src/scripts/setupEnvFile.js setup-env:dev",
    "wipe-data:dev": "cross-env NODE_ENV=development node src/scripts/wipeDatabase.js",
    "wipe-data:prod": "node src/scripts/wipeDatabase.js",
    "codebase-info": "node src/scripts/linesOfCode.js",
    "commit": "node src/scripts/commitRunner.js",
    "log-setup": "node src/scripts/setupLogs.js"
  },
  "author": "Kkermit",
  "license": "MIT",
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.16.1",
    "@distube/soundcloud": "^2.0.4",
    "@distube/spotify": "^2.0.2",
    "@distube/yt-dlp": "^2.0.1",
    "@distube/ytsr": "^2.0.4",
    "@iamtraction/google-translate": "^1.1.2",
    "@napi-rs/canvas": "^0.1.55",
    "apexify.js": "^4.9.25",
    "ascii-table": "^0.0.9",
    "axios": "^1.11.0",
    "canvacord": "^5.4.10",
    "canvafy": "^7.1.5",
    "captcha-canvas": "^2.3.1",
    "cors": "^2.8.5",
    "discord-arts": "^0.7.1",
    "discord-gamecord": "^4.4.2",
    "discord-giveaways": "^6.0.1",
    "discord-html-transcripts": "^3.2.0",
    "discord-logs": "^2.2.1",
    "discord.js": "^14.22.1",
    "distube": "^5.0.7",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.2.0",
    "figlet": "^1.7.0",
    "hercai": "^12.3.2",
    "inquirer": "^9.3.7",
    "libsodium-wrappers": "^0.7.13",
    "mathjs": "^12.4.3",
    "moment": "^2.30.1",
    "mongoose": "^8.18.0",
    "ngrok": "^4.3.0",
    "punycode": "^2.2.2",
    "puppeteer": "^24.17.1",
    "puppeteer-cluster": "^0.24.0",
    "quickchart-js": "^3.1.3",
    "sharp": "^0.33.5",
    "wikijs": "^6.4.1",
    "yt-search": "^2.12.1"
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-transform-modules-commonjs": "^7.25.9",
    "@babel/preset-env": "^7.25.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "babel-jest": "^29.7.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "typescript": "^5.6.3",
    "npm-check-updates": "^18.0.0"
  }
}